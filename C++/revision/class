#include<iostream> 
using namespace std ; 

class Student{
    protected :
    int rollNo , marks[5] ; 
    string name ; 
    
    public :
    Student(){
        cout<<"default constructor " ; 
        rollNo = -1 ; 
        // marks = {-1,-1,-1,-1,-1} ; 
        name = "NULL";
    }
    Student(int r , string n , int m[5] ){ 
        cout<<"Parameterised Constructor" ; 
        rollNo = r ; 
        name = n ; 
        
        for(int i = 0 ; i< 5 ; i++) {
            marks[i] = m[i] ; 
        }
        
    }
    
    void getData(){
        cout<<"RollNO : "<<rollNo << " Name : " <<name <<endl ; 
        cout<<"Marks " <<endl ; 
        
        for(int i = 0 ; i< 5 ; i++) {
            cout<<"Mark "<<i+1 <<" " <<marks[i]<<endl  ; 
        }
        
    }
};
int main () {
    Student s ; 
    return 0 ; 
}