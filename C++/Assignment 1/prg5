#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int num = 0;
    float posSum = 0, divSum = 0, negSum = 0;

    cout << "Enter numbers (Enter -999 to stop):" << endl;
    while (num != -999) {
        cin >> num;
        if (num == -999) break;

        if (num > 0) posSum += num;
        if (num < 0) negSum += num;
        if (num % 9 == 0 && num % 15 == 0) divSum += num;
    }

    cout << "Sum of Positive: " << posSum << endl;
    cout << "Sum of Negative: " << negSum << endl;
    cout << "Sum of Divisible by 9 & 15: " << divSum << endl;

    int choice;
    float r, pi = 3.14159;
    cout << "\n1. Area\n2. Perimeter\n3. Volume\nEnter Choice: ";
    cin >> choice;
    cout << "Enter Radius: ";
    cin >> r;

    switch (choice) {
        case 1:
            cout << "Area: " << pi * r * r << endl;
            break;
        case 2:
            cout << "Perimeter: " << 2 * pi * r << endl;
            break;
        case 3:
            cout << "Volume: " << (4.0/3.0) * pi * pow(r, 3) << endl;
            break;
        default:
            cout << "Invalid Choice" << endl;
    }

    return 0;
}
